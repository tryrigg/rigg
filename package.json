{
  "name": "rigg",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "bun run check:rigg && bun run check:www",
    "check:rigg": "bun run --cwd packages/rigg check",
    "check:www": "bun run --cwd packages/www check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rigg": "bun run --cwd packages/rigg rigg",
    "test": "bun run --cwd packages/rigg test"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.8",
    "prettier": "3.8.1"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  }
}
